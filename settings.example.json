{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/hooks/cwd-guard.py"
          },
          {
            "type": "command",
            "command": "python3 /path/to/hooks/auto-commit.py"
          },
          {
            "type": "command",
            "command": "python3 /path/to/hooks/route_model.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /path/to/hooks/obs-mask-hook.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/hooks/bash-fail-guard.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": []
  }
}
