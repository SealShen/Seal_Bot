# 1. 從 @BotFather 取得的 Bot Token
TELEGRAM_TOKEN=

# 2. 你自己的 Telegram User ID（從 @userinfobot 取得）
MY_TELEGRAM_USER_ID=

# 3. Claude Code 執行時的預設工作目錄（可使用絕對路徑）
CLAUDE_WORKING_DIR=C:\Users\<username>\MyClaw

# 4. 額外允許的工作目錄（分號分隔），按鈕「📂 Netivism」會切換到第二個
ALLOWED_DIRS=C:\Users\<username>\Netivism\Claude

# 5. 按鈕目錄的顯示標籤（分號分隔，順序對應 ALLOWED_DIRS）
DIR_LABELS=Netivism

# 6. TOTP QR code 顯示的帳號名稱（在 Google Authenticator 中顯示）
BOT_OWNER_NAME=owner
