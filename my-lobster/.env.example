# MyClaw Bot 環境變數範例
#
# 敏感欄位（TELEGRAM_TOKEN / MY_TELEGRAM_USER_ID / TOTP_SECRET）
# 建議改存 Windows 使用者環境變數，不寫在此檔（詳見 README.md「3. 設定環境變數」）。
# 若要沿用傳統作法寫在 .env，取消下方註解並填值（不推薦，.env 是明文檔）：
#
# TELEGRAM_TOKEN=
# MY_TELEGRAM_USER_ID=
# TOTP_SECRET=

# Claude Code 執行時的預設工作目錄（可使用絕對路徑）
CLAUDE_WORKING_DIR=C:\Users\<username>\MyClaw

# 額外允許的工作目錄（分號分隔），按鈕「📂 Netivism」會切換到第二個
ALLOWED_DIRS=C:\Users\<username>\Netivism\Claude

# 按鈕目錄的顯示標籤（分號分隔，順序對應 ALLOWED_DIRS）
DIR_LABELS=Netivism

# TOTP QR code 顯示的帳號名稱（在 Google Authenticator 中顯示）
BOT_OWNER_NAME=owner
