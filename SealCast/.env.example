# Twitter/X
# 取得方式：developer.twitter.com → Project → App → Keys and tokens
# App permissions 必須設為 "Read and Write"
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

