# ─── Gemini (cloud, OpenAI-compatible endpoint) ────────────────────────────────
# Free tier: https://aistudio.google.com/apikey
LMSTUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LMSTUDIO_API_KEY=your-gemini-api-key-here
LMSTUDIO_MODEL=gemini-2.5-flash-lite       # short-task delegation (MCP gemma_chat)
ANALYZE_MODEL=gemini-2.5-flash             # daily CoT analysis (analyze_sessions.py)
LMSTUDIO_TIMEOUT=180000

# ─── Auto-fallback (used only for short-task gemma_chat, not analyze_sessions) ─
# When primary fails with timeout / network / 429 / 5xx / empty content,
# adapters/lmstudio_client.js::chat() retries with this config.
# Hard errors (400/401/403) skip fallback — misconfiguration won't be fixed by retry.
FALLBACK_BASE_URL=http://localhost:1234/v1
FALLBACK_API_KEY=your-lm-studio-key
FALLBACK_MODEL=google/gemma-4-e4b
FALLBACK_TIMEOUT=60000

# Claude Code 執行時的預設工作目錄
CLAUDE_WORKING_DIR=C:\Users\<username>\MyClaw

# 允許的工作目錄白名單（分號分隔）
ALLOWED_DIRS=C:\Users\<username>\MyClaw;C:\Users\<username>\Netivism\Claude

# 可選：預設 profile (explorer / implementer / architect / security)
# MYCLAW_DEFAULT_PROFILE=explorer
